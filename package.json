{
  "name": "chiri-terminal-monorepo",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @chiri/web",
    "dev:api": "npm run dev -w @chiri/api",
    "build": "npm run build -w @chiri/web",
    "build:web": "npm run build -w @chiri/web",
    "build:api": "npm run build -w @chiri/api",
    "start:web": "npm run start -w @chiri/web",
    "lint": "npm run lint -w @chiri/web"
  }
}
